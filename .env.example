# Backend — PostgreSQL connection string
# Native dev (Windows Postgres on port 5433):
#   postgresql://aegis:aegis@localhost:5433/aegis
# Docker Compose stack (postgres service hostname):
#   postgresql://aegis:aegis@postgres:5432/aegis
DATABASE_URL=postgresql://aegis:aegis@localhost:5433/aegis

# Frontend — backend API base URL (browser-reachable)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Frontend — use built-in mock data instead of live API calls
NEXT_PUBLIC_MOCK_MODE=false
